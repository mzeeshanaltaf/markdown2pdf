# Contact form (n8n webhook) — server-only
N8N_CONTACT_WEBHOOK_URL=
N8N_API_KEY=

# Rate limiting (Upstash Redis) — server-only
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Canonical site origin (no trailing slash). Used for metadata, canonical tags,
# sitemap.xml, robots.txt, and JSON-LD. Defaults to the production domain if unset.
NEXT_PUBLIC_SITE_URL=https://markdown2pdf.zeeshanai.cloud

# Umami analytics (self-hosted). NEXT_PUBLIC_* — must be present at BUILD time.
# The tracker only renders when NEXT_PUBLIC_UMAMI_WEBSITE_ID is set.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
